{
  "name": "@parischap/rolldown-plugin-pure",
  "type": "module",
  "author": "Jérôme MARTIN",
  "license": "MIT",
  "description": "Rollup/rolldown/tsdown plugin that adds @__PURE__ annotations without interfering with minification which it can run along to",
  "homepage": "https://github.com/parischap/rolldown-plugin-pure",
  "scripts": {
    "test-all": "vitest run",
    "lint": "oxlint --disable-nested-config",
    "fmt": "oxfmt --disable-nested-config && oxlint --fix -disable-nested-config",
    "configs": "pnpm -w configs",
    "circular": "madge --extensions ts --circular --no-color --no-spinner esm",
    "check": "pnpm circular && pnpm lint && pnpm test-all",
    "lint-all": "pnpm lint",
    "fmt-all": "pnpm fmt",
    "check-all": "pnpm check",
    "docgen-all": "echo \"No doc generation for 'rolldown-plugin-pure'\"",
    "release": "pnpm publish dist --provenance --no-git-checks --access public",
    "release-all": "pnpm release",
    "update-github-about": "pnpm -w update-github-about"
  },
  "@parischap/configs": {
    "description": "Rollup/rolldown/tsdown plugin that adds @__PURE__ annotations without interfering with minification which it can run along to",
    "moreDetails": "Well tested and documented, 100% Typescript",
    "version": "0.1.1",
    "keywords": [
      "rolldown-plugin",
      "rolldown",
      "rollup",
      "tsdown",
      "plugin",
      "pure",
      "annotation",
      "annotations",
      "side-effects",
      "tree-shaking"
    ],
    "build": {
      "bundling": "NoBundling",
      "generateMaps": false,
      "addPureAnnotations": false,
      "generateCjs": true,
      "minify": true
    },
    "publishTarget": "Npm",
    "docScope": "None",
    "dependencies": {
      "magic-string": "^0.30.21",
      "zimmerframe": "^1.1.4",
      "@jridgewell/remapping": "^2.3.5"
    },
    "devDependencies": {
      "@oxc-project/types": "^0.137.0"
    },
    "environment": "Node",
    "examples": [],
    "peerDependencies": {
      "rolldown": "^1.1.2"
    },
    "scripts": {}
  },
  "exports": {
    ".": {
      "default": "./esm/index.ts"
    }
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "zimmerframe": "^1.1.4",
    "@jridgewell/remapping": "^2.3.5"
  },
  "devDependencies": {
    "@oxc-project/types": "^0.137.0"
  },
  "peerDependencies": {
    "rolldown": "^1.1.2"
  }
}